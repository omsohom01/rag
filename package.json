{
  "name": "rag-backend",
  "version": "1.0.0",
  "description": "RAG chatbot backend with Gemini and Pinecone",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "ingest": "tsx ingestion/ingest.ts",
    "type-check": "tsc --noEmit",
    "test:translation": "tsx scripts/test-translation.ts",
    "test:image": "tsx scripts/test-image.ts",
    "test:image:quick": "tsx scripts/test-image-quick.ts",
    "test:render": "tsx scripts/test-render-endpoint.ts"
  },
  "keywords": [
    "rag",
    "chatbot",
    "gemini",
    "pinecone"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@pinecone-database/pinecone": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "google-translate-api-x": "^10.7.2",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  }
}
