{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini-api-key",
    "PINECONE_API_KEY": "@pinecone-api-key",
    "PINECONE_ENV": "@pinecone-env",
    "PINECONE_INDEX": "@pinecone-index"
  }
}
